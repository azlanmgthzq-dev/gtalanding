# =============================================================================
# GTA LANDING - Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control!
# =============================================================================

# =============================================================================
# SUPABASE - Vector Database for RAG
# =============================================================================
# Get from: https://supabase.com → Project Settings → API
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# =============================================================================
# JINA AI - Embeddings (1024 dimensions)
# =============================================================================
# Get from: https://jina.ai/embeddings/
# Free tier: 1M tokens/month
JINA_API_KEY="jina_xxxx"

# =============================================================================
# LLM PROVIDERS - At least one required
# =============================================================================

# OpenRouter (RECOMMENDED) - Many free models available
# Get from: https://openrouter.ai/keys
# Free models: z-ai/glm-4.5-air:free, google/gemma-2-9b-it:free
OPENROUTER_API_KEY="sk-or-v1-xxxx"

# Google Gemini (ALTERNATIVE)
# Get from: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY="AIzaSyxxxx"

# =============================================================================
# OPTIONAL
# =============================================================================
# Supabase public key (for client-side - not currently used)
# SUPABASE_PUBLISHABLE_DEFAULT_KEY="sb_publishable_xxxx"
